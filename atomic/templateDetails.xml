<?xml version="1.0" encoding="utf-8"?>
<extension type="template" client="site" method="upgrade">
	<name>Atomic</name>
	<version>5.0</version>
	<creationDate>2009-10-10</creationDate>
	<author>Ron Severdia</author>
	<authorEmail>severdia@gmail.com</authorEmail>
	<authorUrl>https://www.severdia.com</authorUrl>
	<copyright>Copyright (C) 2009-2025 Ron Severdia. All rights reserved.</copyright>
	<license>GNU General Public License version 2 or later</license>
	<description>Atomic is an easy-to-modify and minimal example of a Joomla template using Bootstrap. It was previously included in Joomla 2.5.</description>
	<scriptfile>install.php</scriptfile>
	<inheritable>1</inheritable>
	<files>
		<filename>index.php</filename>
		<filename>index.html</filename>
		<filename>templateDetails.xml</filename>
		<filename>component.php</filename>
		<filename>error.php</filename>
		<filename>helper.php</filename>
		<filename>offline.php</filename>
		<filename>joomla.asset.json</filename>
		<folder>html</folder>
		<folder>utilities</folder>
	</files>
	<media destination="templates/site/atomic" folder="media">
		<folder>css</folder>
		<folder>js</folder>
		<folder>fonts</folder>
		<folder>images</folder>
		<folder>favicons</folder>
	</media>
	<positions>
		<position>abovebody</position>
		<position>alert</position>
		<position>belowbody</position>
		<position>breadcrumbs</position>
		<position>debug</position>
		<position>footer</position>
		<position>header</position>
		<position>leftbody</position>
		<position>main-bottom</position>
		<position>main-top</position>
		<position>menu</position>
		<position>mobilemenu</position>
		<position>rightbody</position>
		<position>search</position>
		<position>topmenu</position>
		<position>sidebar-menu</position>
		<!-- Cassiopeia positions -->
		<position>banner</position>
		<position>below-top</position>
		<position>bottom-a</position>
		<position>bottom-b</position>
		<position>sidebar-left</position>
		<position>sidebar-right</position>
		<position>top-a</position>
		<position>top-b</position>
		<position>topbar</position>
	</positions>
	<languages folder="language">
		<language tag="en-GB">en-GB/en-GB.tpl_atomic.ini</language>
		<language tag="en-GB">en-GB/en-GB.tpl_atomic.sys.ini</language>
	</languages>
	<config>
		<fields name="params">
			<fieldset name="JOOMLA_SETTINGS">
				<field name="sitetitle"  type="text" default="" label="TPL_ATOMIC_PAGE_TITLE_LABEL" description="TPL_ATOMIC_PAGE_TITLE_DESC" filter="safehtml" />
				
				
				<field name="sitedescription"  type="text" default="" label="TPL_ATOMIC_SUBHEADING_LABEL" description="TPL_ATOMIC_SUBHEADING_DESC" filter="safehtml" />
				
				<field name="killgenerator" type="radio" class="btn-group btn-group-yesno" label="TPL_ATOMIC_KILLGENERATOR_LABEL" layout="joomla.form.field.radio.switcher" default="0" filter="integer">
						<option value="0">TPL_ATOMIC_NO</option>
						<option value="1">TPL_ATOMIC_YES</option>
				</field>
				
				<field name="casspositions" type="radio" class="btn-group btn-group-yesno" default="0" label="TPL_ATOMIC_CASSPOSITIONS_LABEL" description="TPL_ATOMIC_CASSPOSITIONS_DESC" layout="joomla.form.field.radio.switcher" filter="integer">
					<option value="0">TPL_ATOMIC_NO</option>
					<option value="1">TPL_ATOMIC_YES</option>
				</field>
				
				<field name="copyright" type="radio" class="btn-group btn-group-yesno" default="1" label="TPL_ATOMIC_COPYRIGHT_LABEL" description="TPL_ATOMIC_COPYRIGHT_DESC" layout="joomla.form.field.radio.switcher" filter="integer">
					<option value="0">TPL_ATOMIC_DISABLED</option>
					<option value="1">TPL_ATOMIC_ENABLED</option>
				</field>
				
				<field name="copyrighttxt" showon="copyright:1" type="text" default="" label="TPL_ATOMIC_COPYRIGHTTXT_LABEL" description="TPL_ATOMIC_COPYRIGHTTXT_DESC" filter="string" />
				
				<field name="feediting" type="radio" class="btn-group btn-group-yesno" default="0" label="TPL_ATOMIC_FEEDITING_LABEL" description="TPL_ATOMIC_FEEDITING_DESC" layout="joomla.form.field.radio.switcher" filter="integer">
					<option value="0">TPL_ATOMIC_NO</option>
					<option value="1">TPL_ATOMIC_YES</option>
				</field>
							
			</fieldset>
			
			<fieldset name="CSS_SETTINGS">
				<field name="bootstrapsource" type="list" default="2" label="TPL_ATOMIC_BOOTSTRAP_LABEL" description="TPL_ATOMIC_BOOTSTRAP_DESC" layout="joomla.form.field.list">
					<option value="0">TPL_ATOMIC_NONE</option>
					<option value="3">TPL_ATOMIC_BS5_JOOMLA5</option>
					<option value="1">TPL_ATOMIC_BS5_JOOMLA4</option>
					<option value="2">TPL_ATOMIC_BS5_REMOTE</option>
					<option value="5">TPL_ATOMIC_BS_CUSTOM</option>
					<option value="0" disabled="true">TPL_ATOMIC_BOOTSWATCH_OPTION_LIGHT</option>
					<option value="6">TPL_ATOMIC_BOOTSWATCH_OPTION_COSMO</option>
					<option value="7">TPL_ATOMIC_BOOTSWATCH_OPTION_FLATLY</option>
					<option value="8">TPL_ATOMIC_BOOTSWATCH_OPTION_MINTY</option>
					<option value="9">TPL_ATOMIC_BOOTSWATCH_OPTION_QUARTZ</option>
					<option value="10">TPL_ATOMIC_BOOTSWATCH_OPTION_SPACELAB</option>
					<option value="11">TPL_ATOMIC_BOOTSWATCH_OPTION_YETI</option>
					<option value="0" disabled="true">TPL_ATOMIC_BOOTSWATCH_OPTION_DARK</option>
					<option value="12">TPL_ATOMIC_BOOTSWATCH_OPTION_CYBORG</option>
					<option value="13">TPL_ATOMIC_BOOTSWATCH_OPTION_DARKLY</option>
					<option value="14">TPL_ATOMIC_BOOTSWATCH_OPTION_SLATE</option>
					<option value="15">TPL_ATOMIC_BOOTSWATCH_OPTION_SUPERHERO</option>			
				</field>
				<field name="bootstrapcdn" showon="bootstrapsource:5" type="textarea" label="TPL_ATOMIC_BOOTSTRAPCDN_LABEL" description="TPL_ATOMIC_BOOTSTRAPCDN_DESC" rows="4" columns="30" filter="raw" default="" hint="Example: &#60;link href=&#34;https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css&#34; rel=&#34;stylesheet&#34; integrity=&#34;sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH&#34; crossorigin=&#34;anonymous&#34;&#62;&#160;
	&#60;script src=&#34;https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js&#34; integrity=&#34;sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz&#34; crossorigin=&#34;anonymous&#34;&#62;&#60;/script&#62;" />
				
				<field name="bsfixjoomla" type="radio" class="btn-group btn-group-yesno" default="1" label="TPL_ATOMIC_TEMPLATEBSFIX_LABEL" description="TPL_ATOMIC_TEMPLATEBSFIX_DESC" layout="joomla.form.field.radio.switcher" filter="integer">
					<option value="0">TPL_ATOMIC_NO</option>
					<option value="1">TPL_ATOMIC_YES</option>
				</field>
				
				<field name="fluidcontainer" type="radio" class="btn-group btn-group-yesno" default="0" label="TPL_ATOMIC_FLUID_LABEL" description="TPL_ATOMIC_FLUID_DESC" layout="joomla.form.field.radio.switcher" filter="integer">
					<option value="0">TPL_ATOMIC_FIXED</option>
					<option value="1">TPL_ATOMIC_FLUID</option>
				</field>
				
				<field name="customcssfile" type="radio" class="btn-group btn-group-yesno" default="0" label="TPL_ATOMIC_CUSTOMCSSFILE_LABEL" description="TPL_ATOMIC_CUSTOMCSSFILE_DESC" layout="joomla.form.field.radio.switcher" filter="integer">
					<option value="0">TPL_ATOMIC_NO</option>
					<option value="1">TPL_ATOMIC_YES</option>
				</field>
				
				<field name="bodymenu" type="list" default="0" label="TPL_ATOMIC_BODYMENU_LABEL" description="TPL_ATOMIC_BODYMENU_DESC">
					<option value="0">TPL_ATOMIC_BODYMENU_OPTION_DEFAULT</option>
					<option value="1">TPL_ATOMIC_BODYMENU_OPTION_BODYCLASS</option>
					<option value="2">TPL_ATOMIC_BODYMENU_OPTION_BODYID</option>
					<option value="3">TPL_ATOMIC_BODYMENU_OPTION_BODYCLASSID</option>
				</field>
	
				<field name="bsthemes" type="radio" class="btn-group btn-group-yesno" default="0" label="TPL_ATOMIC_BSTHEMES_LABEL" description="TPL_ATOMIC_BSTHEMES_DESC" layout="joomla.form.field.radio.switcher" filter="integer">
					<option value="0">TPL_ATOMIC_NO</option>
					<option value="1">TPL_ATOMIC_YES</option>
				</field>
				
				<field name="bstheme" type="text" default="" label="TPL_ATOMIC_BSTHEME_LABEL" description="TPL_ATOMIC_BSTHEME_DESC" filter="string" />
				
				<field name="theme" type="text" default="" label="TPL_ATOMIC_THEME_LABEL" description="TPL_ATOMIC_THEME_DESC" filter="string" />
				
			</fieldset>
			
			<fieldset name="JAVASCRIPT_SETTINGS">
				<field name="jqlibrary" type="list" default="0" label="TPL_ATOMIC_JQUERY_LABEL" description="TPL_ATOMIC_JQUERY_DESC">
					<option value="0">TPL_ATOMIC_JQUERY_DEFAULT</option>
					<option value="1">TPL_ATOMIC_JQUERY_3</option>
					<option value="2">TPL_ATOMIC_JQUERYSLIM_3</option>
					<option value="3">TPL_ATOMIC_JQUERY_CUSTOM</option>
					<option value="4">TPL_ATOMIC_NONE</option>
				</field>
				
				<field name="jquerycdn" showon="jqlibrary:3" type="textarea" label="TPL_ATOMIC_JQUERYCDN_LABEL" description="TPL_ATOMIC_JQUERYCDN_DESC" rows="4" columns="30" filter="raw" default="" hint="Example: &#60;script src=&#34;https://code.jquery.com/jquery-3.7.1.min.js&#34; integrity=&#34;sha256-/JqT3SQfawRcv/BIHPThkBvs0OEvtFFmqPF/lYI/Cxo=&#34; crossorigin=&#34;anonymous&#34;>&#60;/script&#62;" />
				
				<field name="customjs" type="radio" class="btn-group btn-group-yesno" default="0" label="TPL_ATOMIC_CUSTOMJS_LABEL" description="TPL_ATOMIC_CUSTOMJS_DESC" layout="joomla.form.field.radio.switcher" filter="integer">
					<option value="0">TPL_ATOMIC_NO</option>
					<option value="1">TPL_ATOMIC_YES</option>
				</field>
	
			</fieldset>
			
			<fieldset name="FONT_SETTINGS">
			
				<field name="headerfont" type="list" default="0" label="TPL_ATOMIC_HEADER_FONT_LABEL" description="TPL_ATOMIC_HEADER_FONT_DESC">
					<option value="0">TPL_ATOMIC_BOOTSTRAPFONT</option>
					<option value="1">TPL_ATOMIC_GOOGLEFONT</option>
					<option value="2">TPL_ATOMIC_NOFONT</option>
					<option value="98" disabled="true">TPL_ATOMIC_GOOGLEFONT_SANSSERIF</option>
					<option value="3">TPL_ATOMIC_GOOGLEFONT_INTER</option>
					<option value="4">TPL_ATOMIC_GOOGLEFONT_LATO</option>
					<option value="5">TPL_ATOMIC_GOOGLEFONT_MONTSERRAT</option>
					<option value="6">TPL_ATOMIC_GOOGLEFONT_OPENSANS</option>
					<option value="7">TPL_ATOMIC_GOOGLEFONT_ROBOTO</option>
					<option value="99" disabled="true">TPL_ATOMIC_GOOGLEFONT_SERIF</option>
					<option value="8">TPL_ATOMIC_GOOGLEFONT_FRAUNCES</option>
					<option value="9">TPL_ATOMIC_GOOGLEFONT_LIBREBASKERVILLE</option>
					<option value="10">TPL_ATOMIC_GOOGLEFONT_MERRIWEATHER</option>
					<option value="11">TPL_ATOMIC_GOOGLEFONT_NOTOSERIF</option>			
					<option value="12">TPL_ATOMIC_GOOGLEFONT_UNNA</option>	
				</field>
				
				<field name="headergooglefont" showon="headerfont:1" type="textarea" label="TPL_ATOMIC_HEADER_FONT_LINK_LABEL" description="TPL_ATOMIC_HEADER_FONT_LINK_DESC" rows="4" columns="30" filter="raw" default="" />
				
				<field name="headerfontname" showon="headerfont:1" type="text" default="" label="TPL_ATOMIC_HEADER_FONTNAME_LABEL" description="TPL_ATOMIC_HEADER_FONTNAME_DESC" filter="string" hint="Example: Inter or &#34;Inter&#34;, sans-serif " />
				
				<field name="bodyfont" type="list" default="0" label="TPL_ATOMIC_BODY_FONT_LABEL" description="TPL_ATOMIC_BODY_FONT_DESC">
					<option value="0">TPL_ATOMIC_BOOTSTRAPFONT</option>
					<option value="1">TPL_ATOMIC_GOOGLEFONT</option>
					<option value="2">TPL_ATOMIC_NOFONT</option>
					<option value="98" disabled="true">TPL_ATOMIC_GOOGLEFONT_SANSSERIF</option>
					<option value="3">TPL_ATOMIC_GOOGLEFONT_INTER</option>
					<option value="4">TPL_ATOMIC_GOOGLEFONT_LATO</option>
					<option value="5">TPL_ATOMIC_GOOGLEFONT_MONTSERRAT</option>
					<option value="6">TPL_ATOMIC_GOOGLEFONT_OPENSANS</option>
					<option value="7">TPL_ATOMIC_GOOGLEFONT_ROBOTO</option>
					<option value="99" disabled="true">TPL_ATOMIC_GOOGLEFONT_SERIF</option>
					<option value="8">TPL_ATOMIC_GOOGLEFONT_FRAUNCES</option>
					<option value="9">TPL_ATOMIC_GOOGLEFONT_LIBREBASKERVILLE</option>
					<option value="10">TPL_ATOMIC_GOOGLEFONT_MERRIWEATHER</option>
					<option value="11">TPL_ATOMIC_GOOGLEFONT_NOTOSERIF</option>			
					<option value="12">TPL_ATOMIC_GOOGLEFONT_UNNA</option>	
				</field>
				
				<field name="bodygooglefont" showon="bodyfont:1" type="textarea" label="TPL_ATOMIC_BODY_FONT_LINK_LABEL" description="TPL_ATOMIC_BODY_FONT_LINK_DESC" rows="4" columns="30" filter="raw" default="" hint="Example: &#60;link rel=&#34;preconnect&#34; href=&#34;https://fonts.googleapis.com&#34;&#62;&#160;
	&#60;link rel=&#34;preconnect&#34; href=&#34;https://fonts.gstatic.com&#34; crossorigin&#62;&#160;
	&#60;link href=&#34;https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,100..900;1,14..32,100..900&#38;display=swap&#34; rel=&#34;stylesheet&#34;&#62;" />
							
				<field name="bodyfontname" showon="bodyfont:1" type="text" default="" label="TPL_ATOMIC_BODY_FONTNAME_LABEL" description="TPL_ATOMIC_BODY_FONTNAME_DESC" filter="string" hint="Example: Inter or &#34;Inter&#34;, sans-serif " />
				
			</fieldset>
			
			<fieldset name="ICON_SETTINGS">
			
				<field name="fontawesome" type="list" default="0" label="TPL_ATOMIC_FONTAWESOME_LABEL" description="TPL_ATOMIC_FONTAWESOME_DESC">
					<option value="0">TPL_ATOMIC_NONE</option>
					<option value="6">TPL_ATOMIC_FAJOOMLA5</option>
					<option value="1">TPL_ATOMIC_FAJOOMLA4</option>
					<option value="2">TPL_ATOMIC_FACSSCDN</option>
					<option value="3">TPL_ATOMIC_FAJSCDN</option>
					<option value="4">TPL_ATOMIC_FACUSTOMCSS</option>
					<option value="5">TPL_ATOMIC_FACUSTOMJS</option>
				</field>
				
				<field name="fontawesomecdn" showon="fontawesome:5[OR]fontawesome:4" type="textarea" filter="raw" label="TPL_ATOMIC_FONTAWESOMECDN_LABEL" description="TPL_ATOMIC_FONTAWESOMECDN_DESC" rows="4" columns="30" hint="Example: &#60;link rel=&#34;stylesheet&#34; href=&#34;https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.6.0/css/all.min.css&#34; integrity=&#34;sha512-Kc323vGBEqzTmouAECnVceyQqyqdsSiqLQISBL29aUW4U/M7pSPA/gEUZQqv1cwx4OnYxTxve5UMg5GT6L4JJg==&#34; crossorigin=&#34;anonymous&#34; referrerpolicy=&#34;no-referrer&#34; /&#62;" />
				
				<field name="loadbsicons" type="radio" class="btn-group btn-group-yesno" default="0" label="TPL_ATOMIC_LOADBSICONS_LABEL" description="TPL_ATOMIC_LOADBSICONS_DESC" layout="joomla.form.field.radio.switcher" filter="integer">
					<option value="0">TPL_ATOMIC_NO</option>
					<option value="1">TPL_ATOMIC_YES</option>
				</field>
				
				<field name="loadfavicons" type="radio" class="btn-group btn-group-yesno" default="0" label="TPL_ATOMIC_LOADFAVICONS_LABEL" description="TPL_ATOMIC_LOADFAVICONS_DESC" layout="joomla.form.field.radio.switcher" filter="integer">
					<option value="0">TPL_ATOMIC_NO</option>
					<option value="1">TPL_ATOMIC_YES</option>
				</field>
				
			</fieldset>
	
			<fieldset name="FEATURE_SETTINGS">
				<field name="gacode"  type="text" default="" label="TPL_ATOMIC_GA_LABEL" description="TPL_ATOMIC_GA_DESC" filter="string" hint="Example: G-TAGID12345" />
	
				<field name="logo" type="media" label="TPL_ATOMIC_LOGO_LABEL" description="TPL_ATOMIC_LOGO_DESC" />
							
				<field name="scrollreveal" type="radio" class="btn-group btn-group-yesno" default="0" label="TPL_ATOMIC_SCROLLREVEAL_LABEL" description="TPL_ATOMIC_SCROLLREVEAL_DESC" layout="joomla.form.field.radio.switcher" filter="integer">
					<option value="0">TPL_ATOMIC_NO</option>
					<option value="1">TPL_ATOMIC_YES</option>
				</field>
				
				<field name="instant" type="radio" class="btn-group btn-group-yesno" default="0" label="TPL_ATOMIC_INSTANT_LABEL" description="TPL_ATOMIC_INSTANT_DESC" layout="joomla.form.field.radio.switcher" filter="integer">
					<option value="0">TPL_ATOMIC_NO</option>
					<option value="1">TPL_ATOMIC_YES</option>
				</field>
				
				<field name="stickyhead" type="radio" class="btn-group btn-group-yesno" default="0" label="TPL_ATOMIC_STICKYHEAD_LABEL" description="TPL_ATOMIC_STICKYHEAD_DESC" layout="joomla.form.field.radio.switcher" filter="integer">
					<option value="0">TPL_ATOMIC_NO</option>
					<option value="1">TPL_ATOMIC_YES</option>
				</field>
	
				<field name="headerbackground" type="color" default="rgb(0,0,0,0)" format="rgba" label="TPL_ATOMIC_HEADER_BACKGROUND_COLOR_LABEL" description="TPL_ATOMIC_HEADER_BACKGROUND_COLOR_DESC" />
	
				<field name="sidebarmenu" type="radio" class="btn-group btn-group-yesno" default="0" label="TPL_ATOMIC_SIDEBARMENU_LABEL" description="TPL_ATOMIC_SIDEBARMENU_DESC" layout="joomla.form.field.radio.switcher" filter="integer">
					<option value="0">TPL_ATOMIC_NO</option>
					<option value="1">TPL_ATOMIC_YES</option>
				</field>
				
				<field name="usergroupdata" type="radio" class="btn-group btn-group-yesno" default="0" label="TPL_ATOMIC_USERGROUPDATA_LABEL" description="TPL_ATOMIC_USERGROUPDATA_DESC" layout="joomla.form.field.radio.switcher" filter="integer">
					<option value="0">TPL_ATOMIC_NO</option>
					<option value="1">TPL_ATOMIC_YES</option>
				</field>
				
			</fieldset>
			
			<fieldset name="METADATA_SETTINGS">
	
				<field name="socialtitle" type="radio" class="btn-group btn-group-yesno" default="0" label="TPL_ATOMIC_SOCIALTITLE_LABEL" description="TPL_ATOMIC_SOCIALTITLE_DESC" layout="joomla.form.field.radio.switcher" filter="integer">
					<option value="0">TPL_ATOMIC_NO</option>
					<option value="1">TPL_ATOMIC_YES</option>
				</field>
				
				<field name="socialdescription" type="radio" class="btn-group btn-group-yesno" default="0" label="TPL_ATOMIC_SOCIALDESCRIPTION_LABEL" description="TPL_ATOMIC_SOCIALDESCRIPTION_DESC" layout="joomla.form.field.radio.switcher" filter="integer">
					<option value="0">TPL_ATOMIC_NO</option>
					<option value="1">TPL_ATOMIC_YES</option>
				</field>
				
				<field name="socialurl" type="radio" class="btn-group btn-group-yesno" default="0" label="TPL_ATOMIC_SOCIALURL_LABEL" description="TPL_ATOMIC_SOCIALURL_DESC" layout="joomla.form.field.radio.switcher" filter="integer">
					<option value="0">TPL_ATOMIC_NO</option>
					<option value="1">TPL_ATOMIC_YES</option>
				</field>
				
				<field name="socialthumbgoogle" type="media" label="TPL_ATOMIC_SOCIALTHUMBGOOGLE_LABEL" description="TPL_ATOMIC_SOCIALTHUMBGOOGLE_DESC" />
				<field name="socialthumbfacebook" type="media" label="TPL_ATOMIC_SOCIALTHUMBFACEBOOK_LABEL" description="TPL_ATOMIC_SOCIALTHUMBFACEBOOK_DESC" />
				<field name="socialthumbtwitter" type="media" label="TPL_ATOMIC_SOCIALTHUMBTWITTER_LABEL" description="TPL_ATOMIC_SOCIALTHUMBTWITTER_DESC" />		
			</fieldset>
			
			<fieldset name="CUSTOM_CODE">
				<field name="codeafterhead" type="textarea" label="TPL_ATOMIC_CODEAFTERHEAD_LABEL" description="TPL_ATOMIC_CODEAFTERHEAD_DESC" rows="4" columns="30" filter="raw" default="" hint="&#60;style&#62;Example code&#60;/style&#62;" />
				<field name="codebeforehead" type="textarea" label="TPL_ATOMIC_CODEBEFOREHEAD_LABEL" description="TPL_ATOMIC_CODEBEFOREHEAD_DESC" rows="4" columns="30" filter="raw" default="" hint="&#60;style&#62;Example code&#60;/style&#62;" />
				<field name="codeafterbody" type="textarea" label="TPL_ATOMIC_CODEAFTERBODY_LABEL" description="TPL_ATOMIC_CODEAFTERBODY_DESC" rows="4" columns="30" filter="raw" default="" hint="&#60;style&#62;Example code&#60;/style&#62;" />
				<field name="codebeforebody" type="textarea" label="TPL_ATOMIC_CODEBEFOREBODY_LABEL" description="TPL_ATOMIC_CODEBEFOREBODY_DESC" rows="4" columns="30" filter="raw" default="" hint="&#60;style&#62;Example code&#60;/style&#62;" />
			</fieldset>
		</fields>
	</config>
	
	<updateservers>
		<server type="extension" name="Atomic Update Site">https://kontent.github.io/Atomic/update.xml</server>
	</updateservers>
	
</extension>